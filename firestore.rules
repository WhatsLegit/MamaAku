rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Anyone can submit, authenticated can read and delete
    match /contacts/{id} {
      allow read: if request.auth != null;
      allow create: if true;
      allow delete: if request.auth != null;
    }

    // Anyone can submit, authenticated can read and delete
    match /business_apps/{id} {
      allow read: if request.auth != null;
      allow create: if true;
      allow delete: if request.auth != null;
    }

    // Public read/create, authenticated update/delete
    match /testimonials/{id} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if request.auth != null;
    }

    // Orders — open read/write (admin panel reads these)
    match /orders/{id} {
      allow read, write: if true;
    }

    // Products — public read, authenticated write
    match /products/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Users — public read needed for phone duplicate check during signup
    match /users/{uid} {
      allow read: if true;
      allow create: if true;
      allow update: if request.auth != null && request.auth.uid == uid;
      allow delete: if request.auth != null;
    }

    // Config — open read for secret code verification
    match /config/{id} {
      allow read: if true;
      allow write: if false;
    }

    // Admins — authenticated read only, no client writes
    match /admins/{uid} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
